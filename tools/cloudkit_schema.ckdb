DEFINE SCHEMA

    RECORD TYPE Brand (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        color           STRING QUERYABLE SEARCHABLE SORTABLE,
        iconUrl         STRING QUERYABLE SEARCHABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        name            STRING QUERYABLE SEARCHABLE SORTABLE,
        shortName       STRING QUERYABLE SEARCHABLE SORTABLE,
        sortOrder       INT64 QUERYABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE CastMember (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        name            STRING QUERYABLE SEARCHABLE SORTABLE,
        nameKana        STRING QUERYABLE SEARCHABLE SORTABLE,
        nameRomaji      STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE Event (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        brandId         STRING QUERYABLE SEARCHABLE SORTABLE,
        eventType       STRING QUERYABLE SEARCHABLE SORTABLE,
        isSolo          INT64 QUERYABLE SORTABLE,
        isStreaming     INT64 QUERYABLE SORTABLE,
        kind            STRING QUERYABLE SEARCHABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        name            STRING QUERYABLE SEARCHABLE SORTABLE,
        ticketOpenDate    STRING QUERYABLE SEARCHABLE SORTABLE,
        ticketDeadline    STRING QUERYABLE SEARCHABLE SORTABLE,
        ticketLotteryDate STRING QUERYABLE SEARCHABLE SORTABLE,
        ticketUrl         STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        jointBrandIds  STRING QUERYABLE SEARCHABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE Idol (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        age             INT64 QUERYABLE SORTABLE,
        aliases         STRING QUERYABLE SEARCHABLE SORTABLE,
        attribute       STRING QUERYABLE SEARCHABLE SORTABLE,
        birthPlace      STRING QUERYABLE SEARCHABLE SORTABLE,
        birthday        STRING QUERYABLE SEARCHABLE SORTABLE,
        bloodType       STRING QUERYABLE SEARCHABLE SORTABLE,
        brandId         STRING QUERYABLE SEARCHABLE SORTABLE,
        bust            DOUBLE QUERYABLE SORTABLE,
        color           STRING QUERYABLE SEARCHABLE SORTABLE,
        constellation   STRING QUERYABLE SEARCHABLE SORTABLE,
        debutDate       STRING QUERYABLE SEARCHABLE SORTABLE,
        description     STRING QUERYABLE SEARCHABLE SORTABLE,
        gender          STRING QUERYABLE SEARCHABLE SORTABLE,
        handedness      STRING QUERYABLE SEARCHABLE SORTABLE,
        familyName      STRING QUERYABLE SEARCHABLE SORTABLE,
        givenName       STRING QUERYABLE SEARCHABLE SORTABLE,
        height          DOUBLE QUERYABLE SORTABLE,
        hip             DOUBLE QUERYABLE SORTABLE,
        hobbies         STRING QUERYABLE SEARCHABLE SORTABLE,
        isExternal      INT64 QUERYABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        name            STRING QUERYABLE SEARCHABLE SORTABLE,
        nameKana        STRING QUERYABLE SEARCHABLE SORTABLE,
        nameRomaji      STRING QUERYABLE SEARCHABLE SORTABLE,
        nickname        STRING QUERYABLE SEARCHABLE SORTABLE,
        sortOrder       INT64 QUERYABLE SORTABLE,
        talents         STRING QUERYABLE SEARCHABLE SORTABLE,
        voiceActors     STRING QUERYABLE SEARCHABLE SORTABLE,
        waist           DOUBLE QUERYABLE SORTABLE,
        weight          DOUBLE QUERYABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE IdolBrand (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
