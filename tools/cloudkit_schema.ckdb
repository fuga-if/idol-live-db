        eventId         STRING QUERYABLE SEARCHABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        name            STRING QUERYABLE SEARCHABLE SORTABLE,
        performerType   STRING QUERYABLE SEARCHABLE SORTABLE,
