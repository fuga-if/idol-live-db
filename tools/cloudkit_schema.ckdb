        startTime       STRING QUERYABLE SEARCHABLE SORTABLE,
        venue           STRING QUERYABLE SEARCHABLE SORTABLE,
        venueCity       STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE ShowCast (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        castId          STRING QUERYABLE SEARCHABLE SORTABLE,
        idolId          STRING QUERYABLE SEARCHABLE SORTABLE,
        castRole        STRING QUERYABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        showId          STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE Song (
        "___createTime"   TIMESTAMP,
        "___createdBy"    REFERENCE,
        "___etag"         STRING,
        "___modTime"      TIMESTAMP,
        "___modifiedBy"   REFERENCE,
        "___recordID"     REFERENCE,
        appleMusicAlbumId STRING QUERYABLE SEARCHABLE SORTABLE,
        appleMusicId      STRING QUERYABLE SEARCHABLE SORTABLE,
        arranger          STRING QUERYABLE SEARCHABLE SORTABLE,
        artworkUrl        STRING QUERYABLE SEARCHABLE SORTABLE,
        brandId           STRING QUERYABLE SEARCHABLE SORTABLE,
        cdSeries          STRING QUERYABLE SEARCHABLE SORTABLE,
        cdTitle           STRING QUERYABLE SEARCHABLE SORTABLE,
        seriesGroup       STRING QUERYABLE SEARCHABLE SORTABLE,
        composer          STRING QUERYABLE SEARCHABLE SORTABLE,
        durationSec       INT64 QUERYABLE SORTABLE,
        isrc              STRING QUERYABLE SEARCHABLE SORTABLE,
        lyricist          STRING QUERYABLE SEARCHABLE SORTABLE,
        lyricsUrl         STRING QUERYABLE SEARCHABLE SORTABLE,
        modifiedAt        TIMESTAMP QUERYABLE SORTABLE,
        parentSongId      STRING QUERYABLE SEARCHABLE SORTABLE,
        previewUrl        STRING QUERYABLE SEARCHABLE SORTABLE,
        releaseDate       STRING QUERYABLE SEARCHABLE SORTABLE,
        singerLabel       STRING QUERYABLE SEARCHABLE SORTABLE,
        songType          STRING QUERYABLE SEARCHABLE SORTABLE,
        title             STRING QUERYABLE SEARCHABLE SORTABLE,
        titleKana         STRING QUERYABLE SEARCHABLE SORTABLE,
        unitId            STRING QUERYABLE SEARCHABLE SORTABLE,
        unitName          STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
        GRANT READ TO "_world"
    );

    RECORD TYPE SongArtist (
        "___createTime" TIMESTAMP,
        "___createdBy"  REFERENCE,
        "___etag"       STRING,
        "___modTime"    TIMESTAMP,
        "___modifiedBy" REFERENCE,
        "___recordID"   REFERENCE,
        idolId          STRING QUERYABLE SEARCHABLE SORTABLE,
        modifiedAt      TIMESTAMP QUERYABLE SORTABLE,
        role            STRING QUERYABLE SEARCHABLE SORTABLE,
        songId          STRING QUERYABLE SEARCHABLE SORTABLE,
        deletedAt      TIMESTAMP QUERYABLE SORTABLE,
        GRANT WRITE TO "_creator",
        GRANT CREATE TO "_icloud",
